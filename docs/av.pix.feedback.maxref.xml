<c74object name='av.pix.feedback' category='' module=''>

    <digest>
        Mix two textures with feedback
    </digest>

    <description>
        Mix two textures with feedback and various feedback modes
    </description>
    
    <discussion>
        
    </discussion>

    <!--METADATA-->
	<metadatalist>
		<metadata name="author">Timo Hoogland</metadata>
		<metadata name="tag">av-toolbox</metadata>
		<metadata name="tag">audiovisual</metadata>
		<metadata name="tag">composition</metadata>
		<metadata name="tag">live</metadata>
		<metadata name="tag">jitter</metadata>
		<metadata name="tag">opengl</metadata>
		<metadata name="tag">graphics</metadata>
		<metadata name="tag">analysis</metadata>
		<metadata name="tag">msp</metadata>
		<metadata name="tag">max</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
    </inletlist>

    <!-- OUTLETS -->
    <outletlist>
    </outletlist>

    <!-- ARGUMENTS -->
    <objarglist>
        <objarg name='feedback' optional='1' type='float'>
            <digest>feedback amount (default = 0.95)</digest>
            <description>feedback amount (default = 0.95)</description>
        </objarg>
        <objarg name='mode' optional='1' type='int'>
            <digest>feedback mode (options: 0: mix, 1: add, 2: max, 3: sub-falloff-add, default = 0)</digest>
            <description>feedback mode (options: 0: mix, 1: add, 2: max, 3: sub-falloff-add, default = 0)</description>
        </objarg>
    </objarglist>

    <!--MESSAGES-->
    <methodlist>
    <method name='jit_gl_texture'>
        <arglist>
            <arg name='jit_gl_texture' optional='0' type='jit_gl_texture' />
        </arglist>
        <digest>
            Function depends on inlet
        </digest>
        <description>
            inlet 0: Process incoming texture<br/>
inlet 1: Feed back the output texture<br/>

        </description>
    </method>
    <method name='int'>
        <arglist>
            <arg name='int' optional='1' type='int' />
        </arglist>
        <digest>
            Function depends on inlet
        </digest>
        <description>
            Function depends on inlet<br/><br/>
inlet 0: enable/disable processing <br/>
inlet 1: none <br/>
inlet 2: feedback amount (default = 0.95) <br/>
inlet 3: feedback mode (default = 0, linear mix)

        </description>
    </method>
    <method name='float'>
        <arglist>
            <arg name='float' optional='1' type='float' />
        </arglist>
        <digest>
            Function depends on inlet
        </digest>
        <description>
            Function depends on inlet<br/><br/>
inlet 0: enable/disable processing <br/>
inlet 1: none <br/>
inlet 2: feedback amount (default = 0.95) <br/>
inlet 3: feedback mode (default = 0, 0: mix, 1: add, 2: max, 3: sub-falloff-add)

        </description>
    </method>
	</methodlist>

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute 
            name='bypass' 
            type='bool' 
            size='1' 
            get='1' set='1'>
            <digest>
                bypass the pixel processing
            </digest>
            <description>
                bypass the pixel processing
            </description>

            <attributelist>
                <attribute 
                    name='default' 
                    type='bool' 
                    size='1' 
                    value='0' 
                    get='1' set='1' />
            </attributelist>
        </attribute>
        <attribute 
            name='filter' 
            type='symbol' 
            size='1' 
            get='1' set='1'>
            <digest>
                filter for the texture resampling (options: linear, none)
            </digest>
            <description>
                filter for the texture resampling (options: linear, none)
            </description>

            <attributelist>
                <attribute 
                    name='default' 
                    type='symbol' 
                    size='1' 
                    value='linear' 
                    get='1' set='1' />
            </attributelist>
        </attribute>
	</attributelist>

