<c74object name='av.pix.xfade' category='' module=''>

    <digest>
        Crossfade between two textures
    </digest>

    <description>
        Like jit.fxade, a basic crossfade between 2 texture inputs with a cosine ramp for easing in the fade.
    </description>
    
    <discussion>
        
    </discussion>

