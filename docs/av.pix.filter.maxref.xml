<c74object name='av.pix.filter' category='' module=''>

    <digest>
        Apply a convolution filter like sobel, dilate, emboss, etc.
    </digest>

    <description>
        Various convolution filter modes for texture inputs. Filters include: Blur, edgedetect, sobel, dilate, emboss, erode, laplace, radialblur, sharpen. Use an index to select filtermode and dump to fill a umenu for easy selection through names. Collects many built-in .jxs filters
    </description>
    
    <discussion>
        
    </discussion>

    <!--METADATA-->
	<metadatalist>
		<metadata name="author">Timo Hoogland</metadata>
		<metadata name="tag">av-toolbox</metadata>
		<metadata name="tag">audiovisual</metadata>
		<metadata name="tag">composition</metadata>
		<metadata name="tag">live</metadata>
		<metadata name="tag">jitter</metadata>
		<metadata name="tag">opengl</metadata>
		<metadata name="tag">graphics</metadata>
		<metadata name="tag">analysis</metadata>
		<metadata name="tag">msp</metadata>
		<metadata name="tag">max</metadata>
	</metadatalist>

    <!-- INLETS -->
    <inletlist>
    </inletlist>

    <!-- OUTLETS -->
    <outletlist>
    </outletlist>

    <!-- ARGUMENTS -->
    <objarglist>
        <objarg name='mode' optional='1' type='symbol'>
            <digest>filter mode (default = sobel, see helpfile for options)</digest>
            <description>filter mode (default = sobel, see helpfile for options)</description>
        </objarg>
        <objarg name='feedback' optional='1' type='float'>
            <digest>filter amount (default = 1)</digest>
            <description>filter amount (default = 1)</description>
        </objarg>
    </objarglist>

    <!--MESSAGES-->
    <methodlist>
    <method name='jit_gl_texture'>
        <arglist>
            <arg name='jit_gl_texture' optional='0' type='jit_gl_texture' />
        </arglist>
        <digest>
            Process an incoming texture
        </digest>
        <description>
            Process an incoming texture
        </description>
    </method>
    <method name='int'>
        <arglist>
            <arg name='int' optional='1' type='int' />
        </arglist>
        <digest>
            Function depends on inlet
        </digest>
        <description>
            Function depends on inlet<br/><br/>
inlet 0: enable/disable processing <br/>
inlet 1: filter mode (default = sobel) <br/>
inlet 3: filter amount (default = 1)

        </description>
    </method>
    <method name='float'>
        <arglist>
            <arg name='float' optional='1' type='float' />
        </arglist>
        <digest>
            Function depends on inlet
        </digest>
        <description>
            Function depends on inlet<br/><br/>
inlet 0: enable/disable processing <br/>
inlet 1: filter mode (default = sobel) <br/>
inlet 3: filter amount (default = 1)

        </description>
    </method>
    <method name='dump'>
        <arglist>
        </arglist>
        <digest>
            Fill a umenu with filter modes
        </digest>
        <description>
            Fill a umenu with filter modes
        </description>
    </method>
	</methodlist>

	<!--ATTRIBUTES-->
	<attributelist>
        <attribute 
            name='bypass' 
            type='bool' 
            size='1' 
            get='1' set='1'>
            <digest>
                bypass the pixel processing
